# ProcessZero Environment Variables
# Copy this file to .processzero.env and fill in your values
# DO NOT commit .processzero.env to version control

# Database
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=processzero;User=your-db-user;Password=your-db-password;

# JWT Authentication
Jwt__Key=your-super-secret-jwt-key-minimum-32-characters-long
Jwt__Issuer=ProcessZero
Jwt__Audience=ProcessZeroUsers

# Cal.com Integration
CalOptions__BaseUrl=https://api.cal.com/v2
CalOptions__ApiKey=your-calcom-api-key

# Paystack Payment Gateway
Paystack__SecretKey=your-paystack-secret-key

# PayFast Payment Gateway
PayFast__MerchantId=your-payfast-merchant-id
PayFast__MerchantKey=your-payfast-merchant-key
PayFast__Passphrase=your-payfast-passphrase
PayFast__UseSandbox=true

# Assessment Settings
Assessment__PassMark=70.0

# Payroll Settings
Payroll__CommissionRate=0.20

# Data Protection
DataProtection__Purposes__BankAccount=ProcessZero.BankAccountService.V1

# LLM Configuration
LLM__Model=llama3:latest

# CORS Allowed Origins
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:5173
Cors__AllowedOrigins__2=http://77.93.155.211
Cors__AllowedOrigins__3=https://77.93.155.211
Cors__AllowedOrigins__4=https://processzero.xyz
Cors__AllowedOrigins__5=https://www.processzero.xyz

# Google OAuth
GoogleOAuth__ClientId=your-google-oauth-client-id
GoogleOAuth__ClientSecret=your-google-oauth-client-secret
GoogleOAuth__RedirectUri=https://localhost:7183/api/googleauth/callback

# Twilio SMS
Twilio__AccountSid=your-twilio-account-sid
Twilio__AuthToken=your-twilio-auth-token
Twilio__PhoneNumber=+1234567890

# Relay Settings
Relay__PublicBaseUrl=https://api.processzero.xyz
Relay__SendWindowStartHour=0
Relay__SendWindowEndHour=24
Relay__SendOnWeekends=true
Relay__SendJitterSkipPercent=0